// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  tier         String   @default("free") // "free", "pro", "enterprise"
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  // Relations
  documents    Document[]
  conversations Conversation[]
  tokens       RefreshToken[]
  accessLogs   AccessLog[]
  usageLogs    UsageLog[]
  blacklistedTokens BlacklistedToken[]

  @@index([email])
  @@index([role])
  @@index([tier])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([role, deletedAt])
  @@index([tier, deletedAt])
  @@index([isActive, deletedAt])
  @@map("users")
}

model Document {
  id          String   @id @default(uuid())
  userId      String
  title       String
  content     String   @db.Text
  status      String   @default("pending") // "pending", "processing", "completed", "failed"
  fileUrl     String?  // URL to stored file
  fileSize    Int?     // File size in bytes
  mimeType    String?  // MIME type of the file
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  deletedBy   String?

  // Relations
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  chunks       Chunk[]
  accessLogs   AccessLog[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([deletedAt, status])
  @@map("documents")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@index([deletedAt])
  @@index([token])
  @@map("refresh_tokens")
}

model AccessLog {
  id         String   @id @default(uuid())
  userId     String
  documentId String?
  action     String   // "view", "download", "edit", "delete", "share"
  ipAddress  String?
  userAgent  String?
  metadata   Json?    // Additional metadata about the action
  createdAt  DateTime @default(now())
  deletedAt  DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([documentId])
  @@index([action])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([userId, createdAt])
  @@index([documentId, createdAt])
  @@index([action, createdAt])
  @@index([ipAddress])
  @@map("access_logs")
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  reason    String?  // Reason for blacklisting
  expiresAt DateTime
  createdAt DateTime @default(now())
  deletedAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([token])
  @@map("blacklisted_tokens")
}

model Conversation {
  id         String   @id @default(uuid())
  userId     String
  documentId String
  title      String
  status     String   @default("active") // "active", "archived", "deleted"
  lastMessageAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([documentId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@index([userId, status])
  @@index([userId, updatedAt])
  @@index([documentId, status])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id            String   @id @default(uuid())
  conversationId String
  content       String   @db.Text
  role          String   // "user" or "assistant"
  tokenCount    Int?     // Number of tokens in the message
  model         String?  // AI model used for assistant messages
  temperature   Float?   // Temperature setting for AI responses
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([conversationId, role])
  @@index([conversationId, createdAt])
  @@index([role, createdAt])
  @@map("messages")
}

model Chunk {
  id         String   @id @default(uuid())
  documentId String
  index      Int
  content    String
  tokenCount Int
  // Vector embedding — 1536 dimensions for text-embedding-3-small
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now())

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model WebhookEvent {
  id           String   @id @default(uuid())
  eventId      String   @unique // Unique identifier from webhook provider
  eventType    String   // Type of webhook event
  source       String   // Source of the webhook (e.g., "stripe", "github")
  payload      Json     // Full webhook payload
  processed    Boolean  @default(false)
  processedAt  DateTime?
  errorMessage String?  // Error message if processing failed
  retryCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
  @@index([eventType])
  @@index([source])
  @@index([processed])
  @@index([createdAt])
  @@index([processed, createdAt])
  @@index([retryCount])
  @@map("webhook_events")
}

model UsageLog {
  id           String   @id @default(uuid())
  userId       String
  action       String   // "document_created", "document_deleted", "conversation_started", etc.
  resourceType String?  // "document", "conversation", "message", "user", etc.
  resourceId   String?  // ID of the resource being acted upon
  metadata     Json?    // Additional metadata about the action (cost, duration, etc.)
  ipAddress    String?  // IP address of the user
  userAgent    String?  // User agent string
  cost         Float?   // Cost associated with the action (e.g., API call cost)
  duration     Int?     // Duration of the action in milliseconds
  createdAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@index([userId, action])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, createdAt])
  @@index([cost])
  @@index([ipAddress])
  @@map("usage_logs")
}

model PromptTemplate {
  id        String   @id @default(uuid())
  taskType  String               // 'chat', 'agent', 'summary'
  version   String               // 'v1', 'v2', 'v3'
  name      String               // Human-readable name
  content   String   @db.Text    // The actual prompt text
  isActive  Boolean  @default(false)
  metadata  String?              // JSON: notes, author, changelog
  createdAt DateTime @default(now())

  @@unique([taskType, version])
  @@index([taskType, isActive])
  @@map("prompt_templates")
}

model AIAuditLog {
  id             String   @id @default(uuid())
  userId         String
  correlationId  String
  taskType       String
  model          String
  promptVersion  String
  inputTokens    Int
  outputTokens   Int
  costUsd        Float
  latencyMs      Int
  fallbackUsed   Boolean  @default(false)
  inputSummary   String   @db.Text   // First 500 chars of the prompt (not full PII)
  outputSummary  String   @db.Text   // First 500 chars of the response
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([taskType, createdAt])
  @@index([model, createdAt])
  @@map("ai_audit_logs")
}